root {
    platform {
        watchdog_config {
            template watchdog_device {
                serviceName = "HDF_PLATFORM_WATCHDOG_0";
                match_attr = "";
                id = 0;
            }

            device_0x2800A000 :: watchdog_device {
                id = 0;
                match_attr = "phytium_dayu300_watchdog_0";
            }
        }
    }
}
